generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                             String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                          String                           @unique
  passwordHash                   String?                          @map("password_hash")
  metadata                       Json?                            @default("{}")
  createdAt                      DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime                         @default(now()) @map("updated_at") @db.Timestamptz(6)
  agent_buyer_purchases          agent_buyer_purchases[]
  agent_mock_transactions        agent_mock_transactions[]
  agents                         Agent[]
  apiKeys                        ApiKey[]
  audit_logs                     audit_logs[]
  discounts                      discounts[]
  disputes                       disputes[]
  files                          files[]
  idempotency_keys               idempotency_keys[]
  merchant                       Merchant?
  native_apps                    native_apps[]
  pricing_features               pricing_features[]
  pricing_model_history          pricing_model_history[]
  pricing_models                 pricing_models[]
  recurring_payments             recurring_payments[]
  subscription_scheduled_changes subscription_scheduled_changes[]
  subscriptions                  subscriptions[]
  usage_alerts                   usage_alerts[]
  usage_events                   usage_events[]
  usage_meters                   usage_meters[]
  webhookEndpoints               WebhookEndpoint[]
  webhook_events                 webhook_events[]

  @@map("users")
}

model Merchant {
  id                  String                  @id @db.Uuid
  email               String?
  name                String?
  businessName        String?                 @map("business_name")
  createdAt           DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  businessLogoUrl     String?                 @map("business_logo_url")
  details             String?
  website             String?
  contactEmail        String?                 @map("contact_email")
  contactPhone        String?                 @map("contact_phone")
  socialLinks         Json?                   @default("{}") @map("social_links")
  setupCompletedSteps Int[]                   @default([]) @map("setup_completed_steps")
  setupAllComplete    Boolean?                @default(false) @map("setup_all_complete")
  setupApiKeyLocked   Boolean?                @default(false) @map("setup_api_key_locked")
  updatedAt           DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  businessAddress     Json?                   @map("business_address")
  businessCountry     String?                 @map("business_country")
  businessType        String?                 @map("business_type")
  businessIndustry    String?                 @map("business_industry")
  x402PayoutWallet    String?                 @map("x402_payout_wallet")
  x402Network         String?                 @map("x402_network")
  x402FacilitatorUrl  String?                 @map("x402_facilitator_url")
  accountNumber       String?                 @map("account_number")
  annualCcSales       Decimal?                @map("annual_cc_sales") @db.Decimal
  averageTicket       Decimal?                @map("average_ticket") @db.Decimal
  bankName            String?                 @map("bank_name")
  businessStartDate   String?                 @map("business_start_date")
  dbaName             String?                 @map("dba_name")
  highTicket          Decimal?                @map("high_ticket") @db.Decimal
  monthlySalesVolume  Decimal?                @map("monthly_sales_volume") @db.Decimal
  ownershipType       String?                 @map("ownership_type")
  routingNumber       String?                 @map("routing_number")
  signerOwnershipPct  Decimal?                @map("signer_ownership_pct") @db.Decimal
  signerSsn           String?                 @map("signer_ssn")
  signerTitle         String?                 @map("signer_title")
  solaAppId           Int?                    @map("sola_app_id")
  solaRef             String?                 @map("sola_ref")
  taxId               String?                 @map("tax_id")
  privyWalletId       String?                 @map("privy_wallet_id")
  status              String?                 @default("active")
  suspendedAt         DateTime?               @map("suspended_at") @db.Timestamptz(6)
  suspendedBy         String?                 @map("suspended_by")
  suspensionReason    String?                 @map("suspension_reason")
  riskScore           Int?                    @default(0) @map("risk_score")
  adminNotes          String?                 @map("admin_notes")
  posthogDistinctId   String?                 @map("posthog_distinct_id")
  lastActiveAt        DateTime?               @map("last_active_at") @db.Timestamptz(6)
  customers           Customer[]
  invoices            invoices[]
  alerts              MerchantAlert[]
  statusHistory       MerchantStatusHistory[]
  user                User                    @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_links       payment_links[]
  settlements         settlements[]
  transactions        Transaction[]

  @@map("merchants")
}

model Transaction {
  id                String             @id
  merchantId        String             @map("merchant_id") @db.Uuid
  customerId        String?            @map("customer_id") @db.Uuid
  amount            Decimal            @db.Decimal
  net               Decimal            @db.Decimal
  fee               Decimal            @db.Decimal
  status            String             @default("pending")
  type              String             @default("payment")
  description       String?
  customerDetails   Json?              @map("customer_details")
  createdAt         DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  paymentLinkId     String?            @map("payment_link_id")
  customerEmail     String?            @map("customer_email")
  customerName      String?            @map("customer_name")
  customerMobile    String?            @map("customer_mobile")
  customerAddress   Json?              @map("customer_address")
  itemName          String?            @map("item_name")
  itemDescription   String?            @map("item_description")
  itemImage         String?            @map("item_image")
  receiptToken      String?            @map("receipt_token")
  invoiceId         String?            @map("invoice_id") @db.Uuid
  currency          String?            @default("USD")
  paymentMethodInfo Json?              @map("payment_method_info")
  checkoutSessionId String?            @map("checkout_session_id") @db.Uuid
  paymentMethod     String?            @map("payment_method")
  refunds           refunds[]
  checkout_sessions checkout_sessions? @relation(fields: [checkoutSessionId], references: [id], onUpdate: NoAction)
  customers         Customer?          @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoices          invoices?          @relation(fields: [invoiceId], references: [id], onUpdate: NoAction)
  merchant          Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_links     payment_links?     @relation(fields: [paymentLinkId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceId], map: "idx_transactions_invoice_id")
  @@index([merchantId, createdAt(sort: Desc)], map: "idx_transactions_merchant_created")
  @@index([paymentLinkId], map: "idx_transactions_payment_link_id")
  @@index([receiptToken], map: "idx_transactions_receipt_token")
  @@map("transactions")
}

model Agent {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId              String                    @map("merchant_id") @db.Uuid
  name                    String
  description             String?
  definitionUrl           String?                   @map("definition_url")
  method                  String                    @default("POST")
  protectedEndpoints      Json?                     @default("[]") @map("protected_endpoints")
  status                  String                    @default("active")
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  x402PriceUsd            String?                   @map("x402_price_usd")
  maxAmountUsd            String?                   @map("max_amount_usd")
  dailyLimitUsd           String?                   @map("daily_limit_usd")
  authPolicy              String                    @default("require_signature") @map("auth_policy")
  endpointUrl             String?                   @map("endpoint_url")
  agent_mock_transactions agent_mock_transactions[]
  merchant                User                      @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([merchantId, createdAt(sort: Desc)])
  @@map("agents")
}

model ApiKey {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String    @map("merchant_id") @db.Uuid
  name       String
  secretKey  String    @map("secret_key")
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsed   DateTime? @map("last_used") @db.Timestamptz(6)
  keyPrefix  String?   @map("key_prefix") @db.VarChar(16)
  merchant   User      @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([keyPrefix])
  @@map("api_keys")
}

model Customer {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId        String              @map("merchant_id") @db.Uuid
  name              String?
  email             String?
  phone             String?
  address           Json?
  createdAt         DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  status            String?             @default("active")
  checkout_sessions checkout_sessions[]
  merchant          Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices          invoices[]
  subscriptions     subscriptions[]
  transactions      Transaction[]
  usage_alerts      usage_alerts[]
  usage_events      usage_events[]

  @@unique([merchantId, email], map: "customers_merchant_email_unique")
  @@index([merchantId, createdAt(sort: Desc)], map: "idx_customers_merchant_created")
  @@map("customers")
}

model WebhookEndpoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId  String   @map("merchant_id") @db.Uuid
  url         String
  description String?
  secret      String
  enabled     Boolean  @default(true)
  events      String[] @default(["*"])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  merchant    User     @relation(fields: [merchantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("webhook_endpoints")
}

model AdminUser {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String                  @unique
  passwordHash         String                  @map("password_hash")
  name                 String
  role                 AdminRole               @default(VIEWER)
  twoFactorSecret      String?                 @map("two_factor_secret")
  twoFactorEnabled     Boolean                 @default(false) @map("two_factor_enabled")
  twoFactorBackupCodes String[]                @default([]) @map("two_factor_backup_codes")
  avatarUrl            String?                 @map("avatar_url")
  lastLoginAt          DateTime?               @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp          String?                 @map("last_login_ip")
  isActive             Boolean                 @default(true) @map("is_active")
  createdById          String?                 @map("created_by") @db.Uuid
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs            AdminAuditLog[]
  createdBy            AdminUser?              @relation("CreatedByAdmin", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAdmins        AdminUser[]             @relation("CreatedByAdmin")
  acknowledgedAlerts   MerchantAlert[]         @relation("AcknowledgedBy")
  resolvedAlerts       MerchantAlert[]         @relation("ResolvedBy")
  statusChanges        MerchantStatusHistory[]

  @@map("admin_users")
}

model AdminAuditLog {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId          String      @map("admin_id") @db.Uuid
  action           AdminAction
  targetMerchantId String?     @map("target_merchant_id") @db.Uuid
  targetAdminId    String?     @map("target_admin_id") @db.Uuid
  metadata         Json?
  ipAddress        String?     @map("ip_address")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  admin            AdminUser   @relation(fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("admin_audit_logs")
}

model MerchantAlert {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId       String        @map("merchant_id") @db.Uuid
  type             AlertType
  severity         AlertSeverity
  title            String
  description      String
  metadata         Json?
  status           AlertStatus   @default(OPEN)
  acknowledgedById String?       @map("acknowledged_by") @db.Uuid
  resolvedById     String?       @map("resolved_by") @db.Uuid
  resolvedAt       DateTime?     @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  acknowledgedBy   AdminUser?    @relation("AcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchant         Merchant      @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolvedBy       AdminUser?    @relation("ResolvedBy", fields: [resolvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("merchant_alerts")
}

model MerchantStatusHistory {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId     String    @map("merchant_id") @db.Uuid
  previousStatus String    @map("previous_status")
  newStatus      String    @map("new_status")
  changedById    String    @map("changed_by") @db.Uuid
  reason         String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  changedBy      AdminUser @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchant       Merchant  @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("merchant_status_history")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model a2a_tasks {
  id         String   @id
  status     String   @default("submitted")
  history    Json     @default("[]")
  artifacts  Json     @default("[]")
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)
}

model agent_buyer_purchases {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyer_merchant_id  String   @db.Uuid
  seller_merchant_id String?  @db.Uuid
  pricing_model_id   String?  @db.Uuid
  agent_id           String?  @db.Uuid
  amount_cents       Int
  currency           String   @default("USD")
  status             String   @default("active")
  description        String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  users              User     @relation(fields: [buyer_merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([buyer_merchant_id, created_at(sort: Desc)])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agent_mock_transactions {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id         String   @db.Uuid
  agent_id            String   @db.Uuid
  kind                String
  credits_used        Int?
  amount_cents        Int?
  currency            String?  @default("USD")
  customer_identifier String?
  description         String?
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  payee_identifier    String?
  agents              Agent    @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               User     @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent_id, created_at(sort: Desc)])
  @@index([merchant_id, kind, created_at(sort: Desc)])
}

model agent_permissions {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id       String    @db.Uuid
  agent_id          String?   @db.Uuid
  api_key_id        String?   @db.Uuid
  permission_type   String    @default("agent")
  name              String
  description       String?
  spend_limit_usd   String?
  timeframe         String?   @default("monthly")
  pricing_model_id  String?   @db.Uuid
  auth_policy       String    @default("require_signature")
  mandate_signature String?
  mandate_signer    String?
  mandate_nonce     String?
  mandate_expires   DateTime? @db.Timestamptz(6)
  status            String    @default("active")
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at        DateTime? @db.Timestamptz(6)

  @@index([agent_id], map: "idx_agent_permissions_agent")
  @@index([merchant_id, status], map: "idx_agent_permissions_merchant_status")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id   String   @db.Uuid
  event_type    String
  resource_type String
  resource_id   String?
  metadata      Json?    @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         User     @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model buyer_wallets {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  privy_did      String   @unique
  wallet_address String
  email          String?
  metadata       Json?    @default("{}")
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([wallet_address])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model checkout_sessions {
