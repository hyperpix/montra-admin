/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model invoices {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id      String          @db.Uuid
  customer_id      String?         @db.Uuid
  title            String?
  description      String?
  payor_name       String?
  payor_email      String?
  amount_due       Decimal         @db.Decimal
  currency         String?         @default("USD")
  invoice_number   String?
  account_code     String?
  reference        String?
  status           String          @default("draft")
  due_date         DateTime?       @db.Timestamptz(6)
  items            Json?
  fee_preference   String?
  payment_type     String?
  created_at       DateTime        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  accepted_methods String[]        @default([])
  payor_address    String?
  customers        Customer?       @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchants        Merchant        @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_links    payment_links[]
  transactions     Transaction[]

  @@index([merchant_id, created_at(sort: Desc)], map: "idx_invoices_merchant_created")
}

model merchant_bank_accounts {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id                String    @db.Uuid
  merchant_name              String?
  bridge_customer_id         String
  bridge_external_account_id String?
  account_label              String?
  bank_name                  String?
  last_four                  String?
  currency                   String    @default("USD")
  payment_rail               String    @default("ach")
  status                     String    @default("pending")
  is_default                 Boolean   @default(true)
  created_at                 DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime  @default(now()) @db.Timestamptz(6)
  payouts                    payouts[]

  @@index([bridge_customer_id], map: "idx_merchant_bank_accounts_bridge_customer_id")
  @@index([merchant_id], map: "idx_merchant_bank_accounts_merchant_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model meter_tiers {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pricing_model_id String         @db.Uuid
  meter_slug       String
  up_to            Decimal?       @db.Decimal
  unit_amount      Decimal        @default(0) @db.Decimal
  flat_amount      Decimal        @default(0) @db.Decimal
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
